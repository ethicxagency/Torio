# Torio Web — Environment Variables (Render / production)
# Set in Render dashboard for the web service.

NODE_ENV=production
PORT=3000

# Public API base URL (must include /api/v1)
NEXT_PUBLIC_API_URL=https://your-api.onrender.com/api/v1

# Optional: used by Next.js if you add server-side fetches later
# API_URL=https://your-api.onrender.com

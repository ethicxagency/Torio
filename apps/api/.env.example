# Torio API — Environment Variables (Render / production)
# Copy to project root .env for local development: cp .env.example .env

# ─── Required ────────────────────────────────────────────────────────────────
DATABASE_URL=
PORT=4000
API_PORT=4000
API_URL=https://your-api.onrender.com
WEB_URL=https://your-app.onrender.com
CORS_ORIGINS=https://your-app.onrender.com,http://localhost:3010
NODE_ENV=production

JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Redis (recommended) ─────────────────────────────────────────────────────
REDIS_URL=

# ─── Meta / WhatsApp ─────────────────────────────────────────────────────────
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=
# Optional overrides (defaults derived from API_URL)
META_OAUTH_REDIRECT_URL=https://your-api.onrender.com/api/v1/channels/meta/callback
META_WEBHOOK_URL=https://your-api.onrender.com/api/v1/webhooks
META_GRAPH_API_VERSION=v21.0
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=

# ─── Google OAuth ────────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-api.onrender.com/api/v1/auth/google/callback

# ─── Email ───────────────────────────────────────────────────────────────────
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=noreply@torio.app

# ─── Storage ─────────────────────────────────────────────────────────────────
S3_ENDPOINT=
S3_REGION=ap-southeast-1
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_PUBLIC_URL=

# ─── AI ──────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-20250514
VOICE_PROVIDER=OPENAI

# ─── Platform admin bootstrap ────────────────────────────────────────────────
PLATFORM_ADMIN_EMAIL=
PLATFORM_ADMIN_PASSWORD=

# ─── Logging ─────────────────────────────────────────────────────────────────
LOG_LEVEL=log

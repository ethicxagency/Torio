# Torio AI eCommerce Messaging Platform — Environment Variables
# Copy to .env:  cp .env.example .env

# Database
DATABASE_URL="postgresql://mango:mango@localhost:5433/mango_messaging?schema=public"

# Redis
REDIS_URL="redis://localhost:6379"

# API
API_PORT=4000
API_URL="http://localhost:4000"
NODE_ENV="development"

# JWT
JWT_ACCESS_SECRET="change-me-access-secret-min-32-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-min-32-chars"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_CALLBACK_URL="http://localhost:4000/api/v1/auth/google/callback"

# Frontend URLs
WEB_URL="http://localhost:3010"
ADMIN_URL="http://localhost:3001"
CORS_ORIGINS="http://localhost:3010,http://localhost:3001"

# Email (SMTP)
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="noreply@torio.app"

# AWS S3 Compatible Storage
S3_ENDPOINT=""
S3_REGION="ap-southeast-1"
S3_BUCKET="mango-messaging"
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_PUBLIC_URL=""

# AI
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4o-mini"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-sonnet-4-20250514"

# Meta (Facebook / Instagram / WhatsApp)
META_APP_ID=""
META_APP_SECRET=""
META_WEBHOOK_VERIFY_TOKEN=""
# Webhook endpoints (configure in Meta Developer Console):
#   ${API_URL}/api/v1/webhooks/meta
#   ${API_URL}/api/v1/webhooks/whatsapp
# Optional full override prefix:
META_WEBHOOK_URL=""
META_OAUTH_REDIRECT_URL="http://localhost:4000/api/v1/channels/meta/callback"
META_GRAPH_API_VERSION="v21.0"

# WhatsApp Cloud API
WHATSAPP_PHONE_NUMBER_ID=""
WHATSAPP_BUSINESS_ACCOUNT_ID=""

# Super Admin Bootstrap
PLATFORM_ADMIN_EMAIL="admin@mango.app"
PLATFORM_ADMIN_PASSWORD="changeme-in-production"

# Demo tenant (web app login at http://localhost:3010/auth/login)
DEMO_USER_EMAIL="demo@torio.app"
DEMO_USER_PASSWORD="demo123456"

  lastSyncError  String?
  isActive       Boolean              @default(true)
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  importJobs   ProductImportJob[]
  products     ProductMemory[]

  @@index([organizationId])
  @@index([type])
  @@index([schedule])
  @@map("product_sync_sources")
}

model ProductImportJob {
  id             String                 @id @default(cuid())
  organizationId String
  syncSourceId   String
  status         ProductImportJobStatus @default(PENDING)
  importedCount  Int                    @default(0)
  updatedCount   Int                    @default(0)
  errorCount     Int                    @default(0)
  errors         Json?
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncSource   ProductSyncSource @relation(fields: [syncSourceId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([syncSourceId])
  @@index([status])
  @@index([createdAt])
  @@map("product_import_jobs")
}

model VoiceTranscript {
  id               String        @id @default(cuid())
  organizationId   String
  messageId        String
  conversationId   String?
  customerId       String?
  audioUrl         String
  transcript       String
  language         String        @default("bn")
  confidence       Float         @default(0)
  provider         VoiceProvider @default(OPENAI)
  aiResponse       String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  message      Message      @relation(fields: [messageId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  customer     Customer?    @relation(fields: [customerId], references: [id], onDelete: SetNull)
  intents      VoiceIntent[]

  @@index([organizationId])
  @@index([messageId])
  @@index([conversationId])
  @@index([customerId])
  @@map("voice_transcripts")
}

model VoiceIntent {
  id                String           @id @default(cuid())
  organizationId    String
  voiceTranscriptId String
  intent            DetectedIntentType @default(GENERAL)
  salesIntent       SalesIntentType?
  confidence        Float            @default(0)
  metadata          Json?
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt

  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  voiceTranscript VoiceTranscript @relation(fields: [voiceTranscriptId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([voiceTranscriptId])
  @@index([intent])
  @@map("voice_intents")
}

model SalesPlaybook {
  id                 String   @id @default(cuid())
  organizationId     String   @unique
  upsellRules        Json     @default("[]")
  crossSellRules     Json     @default("[]")
  salesScripts       Json     @default("[]")
  objectionHandling  Json     @default("[]")
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("sales_playbooks")
}

model SalesSuggestion {
  id               String                @id @default(cuid())
  organizationId   String
  conversationId   String?
  customerId       String?
  productId        String?
  type             SalesSuggestionType
  salesIntent      SalesIntentType?
  title            String
  content          String
  reason           String?
  metadata         Json?
  status           SalesSuggestionStatus @default(PENDING)
  acceptedAt       DateTime?
  convertedAt      DateTime?
  revenueInfluence Float?
  createdAt        DateTime              @default(now())
  updatedAt        DateTime              @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  product      ProductMemory? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([conversationId])
  @@index([customerId])
  @@index([type])
  @@index([status])
  @@map("sales_suggestions")
}

model RevenueInfluence {
  id               String               @id @default(cuid())
  organizationId   String
  conversationId   String?
  customerId       String?
  productId        String?
  type             RevenueInfluenceType
  amount           Float                @default(0)
  currency         String               @default("BDT")
  description      String?
  metadata         Json?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: SetNull)
  product      ProductMemory? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([conversationId])
  @@index([customerId])
  @@index([type])
  @@index([createdAt])
  @@map("revenue_influences")
}

// ─── AI ────────────────────────────────────────────────────────────────────────

model AiSettings {
  id                   String   @id @default(cuid())
  organizationId       String   @unique
  isEnabled            Boolean  @default(true)
  systemPrompt         String?
  confidenceThreshold  Float    @default(0.7)
  defaultLanguage      String   @default("bn")
  autoReplyEnabled     Boolean  @default(false)
  escalationKeywords   String[] @default(["human", "agent", "মানুষ", "এজেন্ট"])
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("ai_settings")
}

model AiLog {
  id               String              @id @default(cuid())
  organizationId   String
  conversationId   String
  messageId        String?
  prompt           String?
  response         String?
  confidence       Float?
  model            String?
  tokensUsed       Int?
  latencyMs        Int?
  wasEscalated     Boolean             @default(false)
  escalationReason AiEscalationReason?
  createdAt        DateTime            @default(now())
  updatedAt        DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([conversationId])
  @@index([createdAt])
  @@map("ai_logs")
}

// ─── CRM: Segments, Assignments, Activities ───────────────────────────────────

model CustomerSegment {
  id             String      @id @default(cuid())
  organizationId String
  name           String
  description    String?
  type           SegmentType @default(CUSTOM)
  filters        Json        @default("{}")
  isSystem       Boolean     @default(false)
  color          String?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, name])
  @@index([organizationId])
  @@index([type])
  @@map("customer_segments")
}

model CustomerAssignment {
  id             String         @id @default(cuid())
  organizationId String
  customerId     String
  assignedToId   String
  assignedById   String
  assignmentType AssignmentType @default(MANUAL)
  assignedAt     DateTime       @default(now())
  unassignedAt   DateTime?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  customer   Customer     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  assignedTo User         @relation("CustomerAssignmentTarget", fields: [assignedToId], references: [id])
  assignedBy User         @relation("CustomerAssignmentActor", fields: [assignedById], references: [id])

  @@index([organizationId])
  @@index([customerId])
  @@index([assignedToId])
  @@index([isActive])
  @@map("customer_assignments")
}

model Activity {
  id             String       @id @default(cuid())
  organizationId String
  customerId     String?
  conversationId String?
  userId         String?
  type           ActivityType
  title          String
  description    String?
  metadata       Json?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  deletedAt      DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([customerId])
  @@index([conversationId])
  @@index([type])
  @@index([createdAt])
  @@map("activities")
}

model OrganizationCrmSettings {
  id                      String                 @id @default(cuid())
  organizationId          String                 @unique
  autoAssignmentEnabled   Boolean                @default(false)
  autoAssignmentStrategy  AutoAssignmentStrategy @default(NONE)
  lastAssignedAgentId     String?
  createdAt               DateTime               @default(now())
  updatedAt               DateTime               @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("organization_crm_settings")
}

// ─── Courier & Shipping ──────────────────────────────────────────────────────

model CourierConnection {
  id             String                  @id @default(cuid())
  organizationId String
  provider       CourierProviderType
  accountName    String?
  credentialsEnc String
  status         CourierConnectionStatus @default(PENDING)
  lastSyncAt     DateTime?
  lastError      String?
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipments    Shipment[]

  @@unique([organizationId, provider])
  @@index([organizationId])
  @@index([status])
  @@map("courier_connections")
}

model ShippingDeliverySettings {
  id             String                @id @default(cuid())
  organizationId String                @unique
  responseStyle  TrackingResponseStyle @default(DETAILED)
  language       TrackingLanguage      @default(AUTO)
  syncInterval   TrackingSyncInterval  @default(THIRTY_MINUTES)
  portalEnabled  Boolean               @default(true)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("shipping_delivery_settings")
}

model DeliveryIntelligence {
  id                   String   @id @default(cuid())
  organizationId       String   @unique
  courierPreferences   Json?
  deliveryPolicies     Json?
  shippingRules        Json?
  trackingInstructions String?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@map("delivery_intelligence")
}

model Shipment {
  id                  String              @id @default(cuid())
  organizationId      String
  orderId             String?
  orderNumber         String?
  courierConnectionId String?
  provider            CourierProviderType
  trackingNumber      String
  status              ShipmentStatus      @default(PENDING)
  courierStatus       String?
  recipientName       String?
  recipientPhone      String?
  recipientAddress    String?
  estimatedDelivery   DateTime?
  deliveredAt         DateTime?
  lastSyncedAt        DateTime?
  metadata            Json?
  createdAt           DateTime            @default(now())
  updatedAt           DateTime            @updatedAt

  organization      Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  order             OrderMemory?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  courierConnection CourierConnection? @relation(fields: [courierConnectionId], references: [id], onDelete: SetNull)
  events            ShipmentEvent[]
  trackingLogs      TrackingLog[]

  @@unique([organizationId, trackingNumber, provider])
  @@index([organizationId])
  @@index([orderId])
  @@index([orderNumber])
  @@index([trackingNumber])
  @@index([status])
  @@map("shipments")
}

model ShipmentEvent {
  id             String         @id @default(cuid())
  organizationId String
  shipmentId     String
  status         ShipmentStatus
  description    String
  location       String?
  occurredAt     DateTime
  source         String         @default("courier")
  createdAt      DateTime       @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipment     Shipment     @relation(fields: [shipmentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([shipmentId])
  @@index([occurredAt])
  @@map("shipment_events")
}

model TrackingLog {
  id             String   @id @default(cuid())
  organizationId String
  shipmentId     String?
  orderId        String?
  orderNumber    String?
  trackingNumber String?
  action         String
  source         String?
  status         String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  shipment     Shipment?    @relation(fields: [shipmentId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([shipmentId])
  @@index([action])
  @@index([createdAt])
  @@map("tracking_logs")
}

// ─── Notifications ───────────────────────────────────────────────────────────

model Notification {
  id             String               @id @default(cuid())
  organizationId String
  userId         String
  type           NotificationType
  category       NotificationCategory
  title          String
  body           String
  data           Json?
  readAt         DateTime?
  emailSentAt    DateTime?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([userId])
  @@index([readAt])
  @@map("notifications")
}

// ─── Audit Logs ────────────────────────────────────────────────────────────────

model AuditLog {
  id               String      @id @default(cuid())
  organizationId   String?
  userId           String?
  platformAdminId  String?
  action           AuditAction
  resource         String?
  resourceId       String?
  metadata         Json?
  ipAddress        String?
  userAgent        String?
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt

  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  user          User?          @relation(fields: [userId], references: [id], onDelete: SetNull)
  platformAdmin PlatformAdmin? @relation(fields: [platformAdminId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

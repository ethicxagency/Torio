  NONE
  ROUND_ROBIN
  LEAST_BUSY
}

// ─── Platform Admin (Super Admin) ────────────────────────────────────────────

model PlatformAdmin {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  name         String
  isActive     Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  auditLogs AuditLog[]

  @@index([email])
  @@map("platform_admins")
}

// ─── Organizations (Tenant Root) ─────────────────────────────────────────────

model Organization {
  id        String             @id @default(cuid())
  name      String
  slug      String             @unique
  country   String             @default("BD")
  timezone  String             @default("Asia/Dhaka")
  currency  String             @default("BDT")
  status    OrganizationStatus @default(ACTIVE)
  industry  String?
  website   String?
  facebookPage String?
  logoUrl   String?
  brandColor String?
  onboardingStep OnboardingStep @default(BUSINESS_INFO)
  onboardingCompletedAt DateTime?
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt
  deletedAt DateTime?

  memberships     Membership[]
  subscriptions   Subscription[]
  usageRecords    UsageRecord[]
  featureFlags    FeatureFlag[]
  channels        Channel[]
  channelConnections ChannelConnection[]
  customers       Customer[]
  conversations   Conversation[]
  tags            Tag[]
  notes           Note[]
  knowledgeBases  KnowledgeBase[]
  aiSettings      AiSettings?
  aiLogs          AiLog[]
  notifications   Notification[]
  auditLogs       AuditLog[]
  invitations     TeamInvitation[]
  activities      Activity[]
  customerSegments CustomerSegment[]
  crmSettings     OrganizationCrmSettings?
  brainCategories BrainCategory[]
  brainEntries    BrainEntry[]
  brainRules      BrainRule[]
  brainFaqs       BrainFAQ[]
  brainDocuments  BrainDocument[]
  brainSettings   BrainSettings?
  brandVoice      BrandVoice?
  learningSuggestions LearningSuggestion[]
  aiConfidenceLogs AiConfidenceLog[]
  customerMemories CustomerMemory[]
  productMemories ProductMemory[]
  productAttributes ProductAttribute[]
  productFaqs ProductFAQ[]
  orderMemories OrderMemory[]
  orderItems OrderItem[]
  customerInsights CustomerInsight[]
  leadScores LeadScore[]
  intentDetections IntentDetection[]
  copilotSuggestions CopilotSuggestion[]
  productSyncSources ProductSyncSource[]
  productImportJobs ProductImportJob[]
  salesPlaybooks SalesPlaybook[]
  salesSuggestions SalesSuggestion[]
  revenueInfluences RevenueInfluence[]
  voiceTranscripts VoiceTranscript[]
  voiceIntents VoiceIntent[]
  memoryGroups MemoryGroup[]
  customMemoryFields CustomMemoryField[]
  customMemoryValues CustomMemoryValue[]
  fieldTemplates FieldTemplate[]
  policyCategories PolicyCategory[]
  shippingPolicies ShippingPolicy[]
  paymentPolicies PaymentPolicy[]
  returnPolicies ReturnPolicy[]
  refundPolicies RefundPolicy[]
  exchangePolicies ExchangePolicy[]
  cancellationPolicies CancellationPolicy[]
  policyVersions PolicyVersion[]
  courierConnections CourierConnection[]
  shippingDeliverySettings ShippingDeliverySettings?
  deliveryIntelligence DeliveryIntelligence?
  shipments Shipment[]
  shipmentEvents ShipmentEvent[]
  trackingLogs TrackingLog[]

  @@index([slug])
  @@index([status])
  @@map("organizations")
}

// ─── Users & Auth ────────────────────────────────────────────────────────────

model User {
  id              String    @id @default(cuid())
  email           String    @unique
  passwordHash    String?
  name            String?
  avatarUrl       String?
  emailVerifiedAt DateTime?
  isActive        Boolean   @default(true)
  lastLoginAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  memberships          Membership[]
  refreshTokens        RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens  PasswordResetToken[]
  oauthAccounts        OAuthAccount[]
  assignedConversations Conversation[] @relation("AssignedAgent")
  assignedByConversations Conversation[] @relation("AssignedByAgent")
  sentMessages         Message[]      @relation("AgentMessages")
  assignmentsReceived  ConversationAssignment[] @relation("AssignmentTarget")
  assignmentsMade      ConversationAssignment[] @relation("AssignmentActor")
  notes                Note[]
  notifications        Notification[]
  auditLogs            AuditLog[]
  invitationsSent      TeamInvitation[] @relation("InvitedBy")
  customersCreated     Customer[]       @relation("CustomerCreatedBy")
  customersAssigned    Customer[]       @relation("CustomerAssignedAgent")
  customerAssignmentsReceived CustomerAssignment[] @relation("CustomerAssignmentTarget")
  customerAssignmentsMade CustomerAssignment[] @relation("CustomerAssignmentActor")
  activities           Activity[]

  @@index([email])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  userAgent String?
  ipAddress String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model OAuthAccount {
  id             String   @id @default(cuid())
  userId         String
  provider       String
  providerUserId String
  accessToken    String?
  refreshToken   String?
  expiresAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerUserId])
  @@index([userId])
  @@map("oauth_accounts")
}

// ─── Memberships & RBAC ──────────────────────────────────────────────────────

model Membership {
  id             String         @id @default(cuid())
  organizationId String
  userId         String
  role           MembershipRole @default(AGENT)
  isActive       Boolean        @default(true)
  joinedAt       DateTime       @default(now())
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  deletedAt      DateTime?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([organizationId])
  @@index([userId])
  @@index([role])
  @@map("memberships")
}

model Permission {
  id          String   @id @default(cuid())
  key         String   @unique
  name        String
  description String?
  module      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  rolePermissions RolePermission[]

  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id           String         @id @default(cuid())
  role         MembershipRole
  permissionId String
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([role, permissionId])
  @@index([role])
  @@map("role_permissions")
}

model TeamInvitation {
  id             String         @id @default(cuid())
  organizationId String
  email          String
  role           MembershipRole @default(AGENT)
  tokenHash      String         @unique
  invitedById    String
  expiresAt      DateTime
  acceptedAt     DateTime?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  invitedBy    User         @relation("InvitedBy", fields: [invitedById], references: [id])

  @@index([organizationId])
  @@index([email])
  @@map("team_invitations")
}

// ─── Subscriptions & Billing ─────────────────────────────────────────────────

model Plan {
  id              String          @id @default(cuid())
  name            String
  slug            String          @unique
  description     String?
  priceMonthly    Int             @default(0)
  priceYearly     Int             @default(0)
  currency        String          @default("BDT")
  billingInterval BillingInterval @default(MONTHLY)
  maxAgents       Int             @default(3)
  maxChannels     Int             @default(3)
  maxMessages     Int             @default(1000)
  maxAiReplies    Int             @default(500)
  maxStorageMb    Int             @default(500)
  features        Json            @default("[]")
  isActive        Boolean         @default(true)
  sortOrder       Int             @default(0)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  deletedAt       DateTime?

  subscriptions Subscription[]
  coupons       Coupon[]

  @@index([slug])
  @@index([isActive])
  @@map("plans")
}

model Subscription {
  id                   String             @id @default(cuid())
  organizationId       String
  planId               String
  status               SubscriptionStatus @default(TRIALING)
  currentPeriodStart   DateTime
  currentPeriodEnd     DateTime
  trialEndsAt          DateTime?
  cancelledAt          DateTime?
  externalSubscriptionId String?
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan         Plan         @relation(fields: [planId], references: [id])

  @@index([organizationId])
  @@index([status])
  @@map("subscriptions")
}

model Coupon {
  id            String    @id @default(cuid())
  code          String    @unique
  planId        String?
  discountPercent Int?
  discountAmount  Int?
  maxUses       Int?
  usedCount     Int       @default(0)
  validFrom     DateTime
  validUntil    DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  plan Plan? @relation(fields: [planId], references: [id])

  @@index([code])
  @@map("coupons")
}

model UsageRecord {
  id             String      @id @default(cuid())
  organizationId String
  metric         UsageMetric
  value          Int         @default(0)
  periodStart    DateTime
  periodEnd      DateTime
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, metric, periodStart])
  @@index([organizationId])
  @@index([periodStart])
  @@map("usage_records")
}

model FeatureFlag {
  id             String   @id @default(cuid())
  organizationId String
  key            String
  enabled        Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, key])
  @@index([organizationId])
  @@map("feature_flags")
}

// ─── Channels ────────────────────────────────────────────────────────────────

model Channel {
  id               String        @id @default(cuid())
  organizationId   String
  type             ChannelType
  name             String
  status           ChannelStatus @default(PENDING)
  externalId       String?
  accessToken      String?
  refreshToken     String?
  tokenExpiresAt   DateTime?
  webhookSecret    String?
  metadata         Json?
  lastSyncAt       DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  deletedAt        DateTime?

  organization  Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  connection    ChannelConnection?
  conversations Conversation[]

  @@unique([organizationId, type, externalId])
  @@index([organizationId])
  @@index([type])
  @@index([status])
  @@map("channels")
}

model ChannelConnection {
  id                        String   @id @default(cuid())
  organizationId            String
  channelId                 String   @unique
  pageId                    String?
  pageName                  String?
  instagramAccountId        String?
  instagramUsername         String?
  whatsappBusinessAccountId String?
  whatsappPhoneNumber       String?
  whatsappPhoneNumberId     String?
  accessToken               String
  refreshToken              String?
  tokenExpiresAt            DateTime?
  verificationStatus        String   @default("pending")
  webhookSubscribed         Boolean  @default(false)
  metadata                  Json?
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel      Channel      @relation(fields: [channelId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([pageId])
  @@index([instagramAccountId])
  @@index([whatsappPhoneNumberId])
  @@map("channel_connections")
}

model OAuthState {
  id             String   @id @default(cuid())
  organizationId String
  userId         String
  provider       String
  state          String   @unique
  channelType    ChannelType?
  redirectUrl    String?
  resultPayload  Json?
  expiresAt      DateTime
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([organizationId])
  @@index([expiresAt])
  @@map("oauth_states")
}

// ─── Customers ───────────────────────────────────────────────────────────────

model Customer {
  id               String         @id @default(cuid())
  organizationId   String
  fullName         String?
  phone            String?
  email            String?
  facebookId       String?
  facebookProfile  String?
  instagramId      String?
  instagramProfile String?
  whatsappNumber   String?
  avatarUrl        String?
  customerType     CustomerType   @default(LEAD)
  leadSource       LeadSource?
  status           CustomerStatus @default(NEW_LEAD)
  assignedAgentId  String?
  createdById      String?
  totalOrders      Int            @default(0)
  metadata         Json?
  firstContactAt   DateTime?
  lastContactAt    DateTime?
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  deletedAt        DateTime?

  organization  Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  assignedAgent User?                @relation("CustomerAssignedAgent", fields: [assignedAgentId], references: [id])
  createdBy     User?                @relation("CustomerCreatedBy", fields: [createdById], references: [id])
  conversations Conversation[]
  tags          CustomerTag[]
  notes         Note[]
  assignments   CustomerAssignment[]
  activities    Activity[]
  memories      CustomerMemory[]
  orders        OrderMemory[]
  insight       CustomerInsight?
  leadScore     LeadScore?
  intentDetections IntentDetection[]
  copilotSuggestions CopilotSuggestion[]
  salesSuggestions SalesSuggestion[]
  revenueInfluences RevenueInfluence[]
  voiceTranscripts VoiceTranscript[]
  customMemoryValues CustomMemoryValue[]

  @@index([organizationId])
  @@index([phone])
  @@index([email])
  @@index([whatsappNumber])
  @@index([status])
  @@index([assignedAgentId])
  @@index([lastContactAt])
  @@map("customers")
}

// ─── Conversations & Messages ────────────────────────────────────────────────

model Conversation {
  id               String             @id @default(cuid())
  organizationId   String
  channelId        String
  customerId       String
  assignedAgentId  String?
  assignedById     String?
  assignedAt       DateTime?
  status           ConversationStatus @default(OPEN)
  subject          String?
  lastMessageAt    DateTime?
  lastMessagePreview String?
  unreadCount      Int                @default(0)
  searchText       String?
  isAiEnabled      Boolean            @default(true)
  closedAt         DateTime?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  deletedAt        DateTime?

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  channel       Channel           @relation(fields: [channelId], references: [id])
  customer      Customer          @relation(fields: [customerId], references: [id])
  assignedAgent User?             @relation("AssignedAgent", fields: [assignedAgentId], references: [id])
  assignedBy    User?             @relation("AssignedByAgent", fields: [assignedById], references: [id])
  messages      Message[]
  tags          ConversationTag[]
  notes         Note[]
  aiLogs        AiLog[]
  assignments   ConversationAssignment[]
  activities    Activity[]
  leadScores    LeadScore[]
  intentDetections IntentDetection[]
  copilotSuggestions CopilotSuggestion[]
  salesSuggestions SalesSuggestion[]
  revenueInfluences RevenueInfluence[]
  voiceTranscripts VoiceTranscript[]

  @@index([organizationId])
  @@index([channelId])
  @@index([customerId])
  @@index([assignedAgentId])
  @@index([status])
  @@index([lastMessageAt])
  @@index([searchText])
  @@map("conversations")
}

model Message {
  id               String            @id @default(cuid())
  organizationId   String
  conversationId   String
  agentId          String?
  direction        MessageDirection
  senderType       MessageSenderType
  content          String
  contentType      MessageContentType @default(TEXT)
  status           MessageStatus     @default(PENDING)
  externalId       String?
  metadata         Json?
  sentAt           DateTime?
  deliveredAt      DateTime?
  readAt           DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  deletedAt        DateTime?

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  agent        User?        @relation("AgentMessages", fields: [agentId], references: [id])
  attachments  Attachment[]
  voiceTranscripts VoiceTranscript[]

  @@index([organizationId])
  @@index([conversationId])
  @@index([externalId])
  @@index([createdAt])
  @@map("messages")
}

model Attachment {
  id             String   @id @default(cuid())
  organizationId String
  messageId      String
  url            String
  mimeType       String
  fileName       String?
  fileSize       Int?
  externalId     String?
  thumbnailUrl   String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([messageId])
  @@map("attachments")
}

model ConversationAssignment {
  id             String         @id @default(cuid())
  organizationId String
  conversationId String
  assignedToId   String
  assignedById   String
  assignmentType AssignmentType @default(MANUAL)
  assignedAt     DateTime       @default(now())
  unassignedAt   DateTime?
  isActive       Boolean        @default(true)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  assignedTo   User         @relation("AssignmentTarget", fields: [assignedToId], references: [id])
  assignedBy   User         @relation("AssignmentActor", fields: [assignedById], references: [id])

  @@index([organizationId])
  @@index([conversationId])
  @@index([assignedToId])
  @@index([isActive])
  @@map("conversation_assignments")
}

// ─── Tags & Notes ──────────────────────────────────────────────────────────────

model Tag {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  color          String   @default("#6366f1")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization  Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations ConversationTag[]
  customers     CustomerTag[]

  @@unique([organizationId, name])
  @@index([organizationId])
  @@map("tags")
}

model ConversationTag {
  id             String   @id @default(cuid())
  organizationId String
  conversationId String
  tagId          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  tag          Tag          @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([conversationId, tagId])
  @@index([organizationId])
  @@map("conversation_tags")
}

model CustomerTag {
  id             String   @id @default(cuid())
  organizationId String
  customerId     String
  tagId          String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  customer Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  tag      Tag      @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([customerId, tagId])
  @@index([organizationId])
  @@map("customer_tags")
}

model Note {
  id             String   @id @default(cuid())
  organizationId String
  conversationId String?
  customerId     String?
  authorId       String
  content        String
  isInternal     Boolean  @default(true)
  mentions       String[] @default([])
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation? @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  customer     Customer?     @relation(fields: [customerId], references: [id], onDelete: Cascade)
  author       User          @relation(fields: [authorId], references: [id])

  @@index([organizationId])
  @@index([conversationId])
  @@index([customerId])
  @@map("notes")
}

// ─── Knowledge Base ────────────────────────────────────────────────────────────

model KnowledgeBase {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  description    String?
  isActive       Boolean  @default(true)
  lastTrainedAt  DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  deletedAt      DateTime?

  organization Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  documents    KnowledgeDocument[]

  @@index([organizationId])
  @@map("knowledge_bases")
}

model KnowledgeDocument {
  id              String                  @id @default(cuid())
  organizationId  String
  knowledgeBaseId String
  title           String
  content         String?
  sourceType      KnowledgeSourceType
  sourceUrl       String?
  fileUrl         String?
  fileSize        Int?
  status          KnowledgeDocumentStatus @default(PENDING)
  metadata        Json?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt
  deletedAt       DateTime?

  knowledgeBase KnowledgeBase    @relation(fields: [knowledgeBaseId], references: [id], onDelete: Cascade)
  chunks        KnowledgeChunk[]

  @@index([organizationId])
  @@index([knowledgeBaseId])
  @@index([status])
  @@map("knowledge_documents")
}

model KnowledgeChunk {
  id             String                      @id @default(cuid())
  organizationId String
  documentId     String
  content        String
  chunkIndex     Int
  tokenCount     Int?
  embedding      Json?
  metadata       Json?
  createdAt      DateTime                    @default(now())
  updatedAt      DateTime                    @updatedAt

  document KnowledgeDocument @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([documentId])
  @@map("knowledge_chunks")
}


}

model FieldTemplate {
  id             String                @id @default(cuid())
  organizationId String?
  name           String
  fieldType      CustomMemoryFieldType
  description    String?
  options        Json?
  scope          CustomMemoryScope     @default(BUSINESS)
  isSystem       Boolean               @default(false)
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt

  organization Organization?     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  fields       CustomMemoryField[]

  @@index([organizationId])
  @@index([isSystem])
  @@map("field_templates")
}

model CustomMemoryField {
  id             String                  @id @default(cuid())
  organizationId String
  groupId        String?
  templateId     String?
  name           String
  fieldType      CustomMemoryFieldType
  description    String?
  options        Json?
  scope          CustomMemoryScope       @default(BUSINESS)
  sortOrder      Int                     @default(0)
  status         CustomMemoryFieldStatus @default(ACTIVE)
  createdAt      DateTime                @default(now())
  updatedAt      DateTime                @updatedAt

  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  group        MemoryGroup?         @relation(fields: [groupId], references: [id], onDelete: SetNull)
  template     FieldTemplate?       @relation(fields: [templateId], references: [id], onDelete: SetNull)
  values       CustomMemoryValue[]

  @@index([organizationId])
  @@index([groupId])
  @@index([status])
  @@index([scope])
  @@index([sortOrder])
  @@map("custom_memory_fields")
}

model CustomMemoryValue {
  id             String   @id @default(cuid())
  organizationId String
  fieldId        String
  entityKey      String   @default("org")
  value          String?
  valueJson      Json?
  customerId     String?
  productId      String?
  orderId        String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  field        CustomMemoryField @relation(fields: [fieldId], references: [id], onDelete: Cascade)
  customer     Customer?         @relation(fields: [customerId], references: [id], onDelete: Cascade)
  product      ProductMemory?    @relation(fields: [productId], references: [id], onDelete: Cascade)
  order        OrderMemory?      @relation(fields: [orderId], references: [id], onDelete: Cascade)

  @@unique([fieldId, entityKey])
  @@index([organizationId])
  @@index([fieldId])
  @@index([customerId])
  @@index([productId])
  @@index([orderId])
  @@map("custom_memory_values")
}

